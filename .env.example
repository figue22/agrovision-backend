# === AgroVision Backend ===

# App
APP_ENV=development
APP_PORT=4000
APP_NAME=AgroVision API

# PostgreSQL + PostGIS
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=agrovision_user
DB_PASSWORD=your_secure_password
DB_DATABASE=agrovision_db
DB_SYNCHRONIZE=false
DB_LOGGING=true

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# OpenWeatherMap
OPENWEATHERMAP_API_KEY=your-openweathermap-api-key

# WhatsApp Business API
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_ACCESS_TOKEN=your-whatsapp-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-id
WHATSAPP_VERIFY_TOKEN=your-verify-token

# ML Service
ML_SERVICE_URL=http://localhost:8000

# RAG Service
RAG_SERVICE_URL=http://localhost:8001

# OpenAI (for chatbot fallback)
OPENAI_API_KEY=your-openai-api-key

JWT_SECRET=agrovision-access-secret-dev-2026-cambiar-en-produccion
JWT_REFRESH_SECRET=agrovision-refresh-secret-dev-2026-cambiar-en-produccion
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
